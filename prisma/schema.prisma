// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Entry {
  id              String   @id @default(cuid())
  date            DateTime
  startTime       DateTime
  endTime         DateTime
  durationSeconds Int
  comment         String
  createdAt       DateTime @default(now())

  @@index([date])
}
